# Modelo de variáveis de ambiente (.env)
# Copie para .env e preencha os valores. Nunca commite .env com dados reais.

SECRET_KEY=
DEBUG=False
DATABASE_URL=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=
# Só para ferramentas/gerar_token.py: code único da URL após login OAuth (remova depois)
# MS_OAUTH_CODE=

# IA no bot WhatsApp: Groq (recomendado, cota free maior) e/ou Gemini (fallback)
GROQ_API_KEY=
GEMINI_API_KEY=
# Opcional: limites de caracteres do contexto. Valores altos causam 413 no Groq (IA perde documentos/URLs).
# Defaults: DOCS=8000, URLS=8000, CONHECIMENTO=18000, SCHEMA=3000
# IA_MAX_CHARS_DOCS=8000
# IA_MAX_CHARS_URLS=8000
# IA_MAX_CHARS_CONHECIMENTO=18000
# IA_MAX_CHARS_SCHEMA=3000

ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Scheduler: rodar em processo/serviço separado (não no Gunicorn)
# Local: python manage.py run_scheduler
# Railway: segundo serviço, start command acima, replicas=1

# Performance (produção Railway)
# FOLHA_COMISSAO_CACHE_ENABLED=True
# FOLHA_COMISSAO_CACHE_TTL=1800
# WHATSAPP_WEBHOOK_ASYNC=True
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=2

CAPTCHA_API_KEY=
CAPTCHA_PROVIDER=capsolver

# Opcional/local
JAWSDB_URL=
NIO_STORAGE_STATE=

# PAP / VENDER no WhatsApp (homologação)
# PAP_WHATSAPP_PERMITIR_FORCAR_SIM_CLIENTE=true
# Com DEBUG=True: após o resumo, confirma o SIM do cliente sozinho (só .env local)
# PAP_WHATSAPP_AUTO_SIM_CLIENTE_LOCAL=true
# PAP_ETAPA7_AGENDAMENTO_TIMEOUT_MS=120000
