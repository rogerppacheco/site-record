# Modelo de variáveis de ambiente (.env)
# Copie para .env e preencha os valores. Nunca commite .env com dados reais.

SECRET_KEY=
DEBUG=False
DATABASE_URL=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=

# IA no bot WhatsApp: Groq (recomendado, cota free maior) e/ou Gemini (fallback)
GROQ_API_KEY=
GEMINI_API_KEY=
# Opcional: limites de caracteres do contexto. Valores altos causam 413 no Groq (IA perde documentos/URLs).
# Defaults: DOCS=12000, URLS=12000, CONHECIMENTO=15000, SCHEMA=4000
# IA_MAX_CHARS_DOCS=12000
# IA_MAX_CHARS_URLS=12000
# IA_MAX_CHARS_CONHECIMENTO=15000
# IA_MAX_CHARS_SCHEMA=4000

ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

CAPTCHA_API_KEY=
CAPTCHA_PROVIDER=capsolver

# Opcional/local
JAWSDB_URL=
NIO_STORAGE_STATE=
