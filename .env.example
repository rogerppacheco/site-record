# Modelo de variáveis de ambiente (.env)
# Copie para .env e preencha os valores. Nunca commite .env com dados reais.

SECRET_KEY=
DEBUG=False
DATABASE_URL=
# PgBouncer (Railway nativo): runtime pooled; migrations/advisory locks via unpooled
# DATABASE_UNPOOLED_URL=
# PGBOUNCER_ENABLED=true
# DB_CONN_MAX_AGE=60

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Cloudflare R2 (armazenamento de arquivos)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=site-record-midia
CLOUDFLARE_R2_PUBLIC_URL=
R2_FOLDER_ROOT=CDOI_Record_Vertical

# IA no bot WhatsApp: Groq (recomendado, cota free maior) e/ou Gemini (fallback)
GROQ_API_KEY=
GEMINI_API_KEY=
# Opcional: limites de caracteres do contexto. Valores altos causam 413 no Groq (IA perde documentos/URLs).
# Defaults: DOCS=8000, URLS=8000, CONHECIMENTO=18000, SCHEMA=3000
# IA_MAX_CHARS_DOCS=8000
# IA_MAX_CHARS_URLS=8000
# IA_MAX_CHARS_CONHECIMENTO=18000
# IA_MAX_CHARS_SCHEMA=3000

ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Scheduler: rodar em processo/serviço separado (não no Gunicorn)
# Local: python manage.py run_scheduler
# Railway: segundo serviço, start command acima, replicas=1

# Performance (produção Railway)
# FOLHA_COMISSAO_CACHE_ENABLED=True
# FOLHA_COMISSAO_CACHE_TTL=1800
# WHATSAPP_WEBHOOK_ASYNC=True
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=2
# FOLHA_COMISSAO_RATE_LIMIT=6
# FOLHA_COMISSAO_RATE_PERIOD=60
# FOLHA_COMISSAO_TIMEOUT_SECONDS=90
# DB_CONN_MAX_AGE=120
# STATIC_CACHE_MAX_AGE=86400

# Sentry (tier gratuito — https://sentry.io)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Serviço PAP dedicado (3º serviço Railway — railway.pap.toml)
# No serviço WEB: PAP_USE_DEDICATED_WORKER=True
# No serviço PAP:  PAP_WORKER_MODE=True
# PAP_WORKER_POLL_SECONDS=2

# Serviço webhook WhatsApp dedicado (4º serviço Railway — railway.webhook.toml)
# No serviço WEB: WHATSAPP_USE_DEDICATED_WORKER=True, WHATSAPP_WEBHOOK_ASYNC=True
# No serviço WEBHOOK: WHATSAPP_WORKER_MODE=True, WHATSAPP_WEBHOOK_ASYNC=False
# WHATSAPP_WORKER_POLL_SECONDS=1

CAPTCHA_API_KEY=
CAPTCHA_PROVIDER=capsolver

# Opcional/local
JAWSDB_URL=
NIO_STORAGE_STATE=

# PAP / VENDER no WhatsApp (homologação)
# PAP_WHATSAPP_PERMITIR_FORCAR_SIM_CLIENTE=true
# Com DEBUG=True: após o resumo, confirma o SIM do cliente sozinho (só .env local)
# PAP_WHATSAPP_AUTO_SIM_CLIENTE_LOCAL=true
# PAP_ETAPA7_AGENDAMENTO_TIMEOUT_MS=120000
